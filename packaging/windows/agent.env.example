# C:\ProgramData\Vigil\agent.env - read by the agent on startup.
# Edit this file before starting the agent for the first time.
#
# Lines beginning with # are comments. Values must NOT contain quotes;
# the install-edr.ps1 launcher parses simple KEY=VALUE pairs.

# gRPC endpoint of the manager (mTLS).
VIGIL_MANAGER_ENDPOINT=https://edr-manager.example.com:50051

# REST endpoint of the manager (used for first-run enrollment).
VIGIL_MANAGER_REST=http://edr-manager.example.com:8000

# One-time enrollment token (mint via the manager's
# POST /api/enrollment/tokens). Required on first run only; the agent
# clears it from disk on disk after successful enrollment.
VIGIL_ENROLLMENT_TOKEN=enr_REPLACE_ME

# Override registered hostname (defaults to system hostname).
# VIGIL_HOSTNAME=my-windows-host

# State directory (default %ProgramData%\Vigil).
# VIGIL_STATE_DIR=C:\ProgramData\Vigil

# Logging.
RUST_LOG=info,edr_agent=info

# Self-protection (M7.2). Driver-side ObRegisterCallbacks; only useful
# when the driver is loaded. VIGIL_DISABLE_SELF_PROTECTION on Linux has
# no effect on the Windows agent (driver-side flag is per-pid registered
# at agent startup; nothing to disable in the agent).
