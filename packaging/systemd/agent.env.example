# /etc/edr/agent.env — sourced by the systemd unit. Copy to agent.env
# and edit before starting the service.

# Manager gRPC endpoint (mTLS). The agent's enrollment cert SAN must
# match the host name in this URL.
EDR_MANAGER_ENDPOINT=https://edr-manager.example.com:50051

# Optional REST endpoint (for enrollment + future config). Defaults to
# the gRPC endpoint with the port replaced and scheme downgraded to http.
#EDR_MANAGER_REST=http://edr-manager.example.com:8000

# State directory: identity, blocklist, spool. Must match the unit's
# ReadWritePaths. Default /var/lib/edr.
#EDR_STATE_DIR=/var/lib/edr

# One-time enrollment token (mint via the manager's
# POST /api/enrollment/tokens). Required on first run only; remove
# this line after the agent has enrolled successfully.
#EDR_ENROLLMENT_TOKEN=enr_REPLACE_ME

# Override registered hostname (defaults to system hostname).
#EDR_HOSTNAME=my-host.example.com

# eBPF tunables.
# EDR_DISABLE_EBPF=1            -- skip eBPF, use /proc-poll fallback
# EDR_DISABLE_SELF_PROTECTION=1 -- skip M7.1 self-protection hooks (dev only)
# EDR_PIN_DIR=/sys/fs/bpf/edr   -- override bpffs pin directory

# Logging.
RUST_LOG=info,edr_agent=info
